generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url is configured in prisma.config.ts — Prisma 7 moved it there
}

// ─── Enums ─────────────────────────────────────────────────────
// An enum is a fixed list of allowed values enforced at the DB level.
// If someone tries to insert "proffesor" (typo) — Postgres rejects it.

enum Role {
  ADMIN // can manage users and edit everything
  EDITOR // can add and edit professors/departments
  VIEWER // read-only access
}

// ─── Auth ──────────────────────────────────────────────────────
// The users table — people who log into the platform.
// Professors and users are separate concepts:
// a professor is data we track, a user is someone with login access.

model User {
  id String @id @default(cuid())
  // cuid() generates a unique string ID like "clh3k2j0f0000..."
  // safer than sequential integers (can't guess other IDs)

  email         String    @unique
  emailVerified DateTime?
  // Auth.js adapter requires this field. We're not doing email verification,
  // but the field must exist or the adapter errors. Nullable = always null for us.

  passwordHash String
  // never store plain text passwords — we store a bcrypt hash

  role Role @default(VIEWER)
  // new users get VIEWER by default — least privilege principle

  divisionId String?
  division   Division? @relation(fields: [divisionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // @updatedAt automatically sets this field whenever the row changes
}

model Division {
  id   String @id @default(cuid())
  name String @unique

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Session table removed — we use JWT sessions (stored in browser cookie, not DB).
// With the Credentials provider, Auth.js requires JWT strategy.
// If we ever switch to OAuth providers, we can add this table back.

// ─── University Structure ──────────────────────────────────────

model Faculty {
  id   String @id @default(cuid())
  name String @unique

  deanId String?  @unique
  dean   Professor? @relation("FacultyDean", fields: [deanId], references: [id])

  departments Department[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id   String @id @default(cuid())
  name String

  facultyId String
  faculty   Faculty @relation(fields: [facultyId], references: [id])

  headId String? @unique
  head   Professor? @relation("DepartmentHead", fields: [headId], references: [id])

  professors Professor[] @relation("DepartmentProfessors")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, facultyId])
}

model Professor {
  id         String  @id @default(cuid())
  lastName   String
  firstName  String
  patronymic String?

  email                 String? @unique
  employmentRate        Float?
  pedagogicalExperience Int?

  academicRank            AcademicRank?
  academicPosition        AcademicPosition?
  scientificDegree        ScientificDegree?
  degreeMatchesDepartment Boolean?

  ratingSheetId String?
  certificateId String?

  wosURL                     String?
  wosCitationCount           Int?    @default(0)
  scopusURL                  String?
  scopusCitationCount        Int?    @default(0)
  googleScholarURL           String?
  googleScholarCitationCount Int?    @default(0)
  orcidId                    String?

  lastAccessVerified DateTime?

  departmentId String
  department   Department @relation("DepartmentProfessors", fields: [departmentId], references: [id])

  headOfDepartment Department? @relation("DepartmentHead")
  deanOfFaculty    Faculty?    @relation("FacultyDean")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Enums ─────────────────────────────────────────────────────

enum AcademicRank {
  DOCENT // доцент (вчене звання, awarded by ministry)
  PROFESSOR // професор (вчене звання)
  SENIOR_RESEARCHER // старший науковий співробітник
}

enum AcademicPosition {
  ASSISTANT // асистент
  LECTURER // викладач
  SENIOR_LECTURER // старший викладач
  DOCENT // доцент (посада)
  PROFESSOR // професор (посада)
}

enum ScientificDegree {
  CANDIDATE // кандидат наук / доктор філософії (PhD)
  DOCTOR // доктор наук
}
