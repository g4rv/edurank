# Normalize line endings to LF in the repository.
# On checkout, Windows gets CRLF locally, Unix/Mac get LF.
* text=auto eol=lf

# Force these file types to always use LF (even on Windows)
# — they are executed on Linux servers where CRLF breaks things
*.sh    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files — don't touch line endings at all
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
